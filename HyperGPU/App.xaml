<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="HyperGPU.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:HyperGPU">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="HyperGpuBackgroundBrush" Color="#FF070D1B" />
                    <SolidColorBrush x:Key="HyperGpuSurfaceBrush" Color="#F20B1224" />
                    <SolidColorBrush x:Key="HyperGpuSurfaceAltBrush" Color="#CC111B34" />
                    <SolidColorBrush x:Key="HyperGpuBorderBrush" Color="#6638BDF8" />
                    <SolidColorBrush x:Key="HyperGpuCyanBrush" Color="#FF06B6D4" />
                    <SolidColorBrush x:Key="HyperGpuCyanSoftBrush" Color="#FF22D3EE" />
                    <SolidColorBrush x:Key="HyperGpuPurpleBrush" Color="#FF7C3AED" />
                    <SolidColorBrush x:Key="HyperGpuGreenBrush" Color="#FF22C55E" />
                    <SolidColorBrush x:Key="HyperGpuMutedTextBrush" Color="#FF94A3B8" />
                    <LinearGradientBrush x:Key="HyperGpuHeroBrush" StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FF08111F" Offset="0" />
                        <GradientStop Color="#FF0B1B34" Offset="0.48" />
                        <GradientStop Color="#FF1D123C" Offset="1" />
                    </LinearGradientBrush>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="HyperGpuBackgroundBrush" Color="#FFF8FAFC" />
                    <SolidColorBrush x:Key="HyperGpuSurfaceBrush" Color="#FFFFFFFF" />
                    <SolidColorBrush x:Key="HyperGpuSurfaceAltBrush" Color="#FFEFF6FF" />
                    <SolidColorBrush x:Key="HyperGpuBorderBrush" Color="#663B82F6" />
                    <SolidColorBrush x:Key="HyperGpuCyanBrush" Color="#FF0284C7" />
                    <SolidColorBrush x:Key="HyperGpuCyanSoftBrush" Color="#FF0369A1" />
                    <SolidColorBrush x:Key="HyperGpuPurpleBrush" Color="#FF7C3AED" />
                    <SolidColorBrush x:Key="HyperGpuGreenBrush" Color="#FF15803D" />
                    <SolidColorBrush x:Key="HyperGpuMutedTextBrush" Color="#FF475569" />
                    <LinearGradientBrush x:Key="HyperGpuHeroBrush" StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FFFFFFFF" Offset="0" />
                        <GradientStop Color="#FFE0F2FE" Offset="0.52" />
                        <GradientStop Color="#FFEDE9FE" Offset="1" />
                    </LinearGradientBrush>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
            <LinearGradientBrush x:Key="HyperGpuAccentBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FF06B6D4" Offset="0" />
                <GradientStop Color="#FF7C3AED" Offset="0.68" />
                <GradientStop Color="#FF22C55E" Offset="1" />
            </LinearGradientBrush>
        </ResourceDictionary>
    </Application.Resources>
</Application>
